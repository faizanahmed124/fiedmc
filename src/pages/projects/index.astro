---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
---

<Layout title="Projects - Umar & Company" description="Projects page - Umar & Company">
  <Navbar />
  <section class="coming-section">
    <div class="blob blob--1" aria-hidden="true"></div>
    <div class="blob blob--2" aria-hidden="true"></div>
    <div class="grid-bg" aria-hidden="true"></div>
    <div class="coming-content">
      <div class="coming-badge">
        <span class="badge-dot"></span>
        Under Construction
        <span class="badge-dot"></span>
      </div>
      <h1 class="coming-heading">
        <span class="h-white">Faizan is </span><span class="h-gold">Working</span><br/>
        <span class="h-white">on </span><span class="h-gold">Projects</span>
      </h1>
      <p class="coming-sub">Our full project portfolio is being compiled. Coming soon.</p>
      <div class="loader" aria-label="Loading">
        <span class="ldot"></span>
        <span class="ldot"></span>
        <span class="ldot"></span>
      </div>
      <a href="/" class="back-btn">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        Back to Home
      </a>
    </div>
  </section>
  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .coming-section {
    position:relative; min-height:100vh; background:#0d0e11;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden; padding:2rem;
  }
  .grid-bg {
    position:absolute; inset:0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),
      linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);
    background-size:52px 52px; pointer-events:none; z-index:0;
  }
  .blob { position:absolute; border-radius:50%; filter:blur(100px); pointer-events:none; z-index:0; }
  .blob--1 { width:500px;height:500px;top:-150px;left:-150px;background:rgba(184,119,22,0.12);animation:bf1 8s ease-in-out infinite alternate; }
  .blob--2 { width:400px;height:400px;bottom:-120px;right:-100px;background:rgba(184,119,22,0.09);animation:bf1 10s ease-in-out infinite alternate-reverse; }
  @keyframes bf1 { from{transform:scale(1)} to{transform:scale(1.2) translate(15px,-15px)} }
  .coming-content {
    position:relative; z-index:1; text-align:center;
    display:flex; flex-direction:column; align-items:center; gap:1.5rem;
    animation:fadeUp 0.8s cubic-bezier(.22,1,.36,1) both;
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(32px)} to{opacity:1;transform:none} }
  .coming-badge {
    display:inline-flex; align-items:center; gap:10px;
    font-family:'DM Sans',sans-serif; font-size:0.72rem; font-weight:600;
    letter-spacing:0.25em; text-transform:uppercase; color:#b87716;
    border:1px solid rgba(184,119,22,0.3); border-radius:999px;
    padding:7px 20px; background:rgba(184,119,22,0.07);
  }
  .badge-dot {
    display:inline-block; width:5px; height:5px; border-radius:50%;
    background:#b87716; opacity:0.8;
    animation:bp 1.8s ease infinite;
  }
  @keyframes bp { 0%,100%{opacity:.8;transform:scale(1)} 50%{opacity:.3;transform:scale(1.4)} }
  .coming-heading {
    font-family:'Playfair Display','Georgia',serif;
    font-weight:800; font-size:clamp(3rem,9vw,7.5rem);
    line-height:1.08; letter-spacing:-0.02em; margin:0;
  }
  .h-white { color:#ffffff; font-style:normal; }
  .h-gold  { color:#b87716; font-style:italic; }
  .coming-sub {
    font-family:'DM Sans',sans-serif; color:#6b7280;
    font-size:clamp(1rem,2vw,1.1rem); line-height:1.8;
    max-width:420px; margin:0;
  }
  .loader { display:flex; gap:10px; align-items:center; margin:0.5rem 0; }
  .ldot {
    width:10px; height:10px; border-radius:50%;
    background:#b87716; opacity:0.8;
    animation:lb 1.2s ease infinite;
  }
  .ldot:nth-child(2){animation-delay:.2s;background:#d4a000;}
  .ldot:nth-child(3){animation-delay:.4s;background:#fff;opacity:.25;}
  @keyframes lb { 0%,80%,100%{transform:scale(1);opacity:.8} 40%{transform:scale(1.5);opacity:1} }
  .back-btn {
    display:inline-flex; align-items:center; gap:8px;
    font-family:'DM Sans',sans-serif; font-size:0.9rem; font-weight:600;
    color:#9ca3af; text-decoration:none;
    border:1px solid rgba(255,255,255,0.1); border-radius:999px;
    padding:10px 24px; background:rgba(255,255,255,0.04);
    transition:color .25s,border-color .25s,background .25s,transform .25s;
    margin-top:0.5rem;
  }
  .back-btn:hover {
    color:#fff; border-color:rgba(184,119,22,0.4);
    background:rgba(184,119,22,0.08); transform:translateX(-4px);
  }
</style>