---
// FooterFIEDMC.astro — white background, unique design
---

<footer class="ft-footer" aria-label="Site footer">

  <!-- Top stats ticker strip -->
  <div class="ft-top-strip" aria-hidden="true">
    <div class="ft-strip-inner">
      <span>Pakistan's Industrial Growth Engine</span>
      <span class="ft-strip-dot"></span>
      <span>7 Industrial Estates</span>
      <span class="ft-strip-dot"></span>
      <span>3,500+ Registered Units</span>
      <span class="ft-strip-dot"></span>
      <span>$2B+ Investment Attracted</span>
      <span class="ft-strip-dot"></span>
      <span>Serving Punjab Since 1990</span>
    </div>
  </div>

  <div class="ft-body">
    <div class="ft-container">

      <!-- Col 1: Brand -->
      <div class="ft-brand">
        <a href="/" class="ft-logo-wrap" aria-label="FIEDMC Home">
          <img src="/images/fiedmc-logo.png" alt="FIEDMC Logo" class="ft-logo" loading="lazy"/>
        </a>
        <p class="ft-brand-desc">
          Faisalabad Industrial Estate Development &amp; Management Company — building
          world-class industrial cities and special economic zones to drive investment,
          employment, and economic growth across Punjab, Pakistan.
        </p>
        <div class="ft-social-row">
          <a href="#" class="ft-social-btn" aria-label="Facebook">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="#" class="ft-social-btn" aria-label="Twitter">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="ft-social-btn" aria-label="LinkedIn">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" class="ft-social-btn" aria-label="YouTube">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>
          </a>
        </div>
        <div class="ft-badge-row">
          <div class="ft-reg-badge">
            <span class="ft-reg-acronym">FBR</span>
            <span class="ft-reg-label">Registered</span>
          </div>
          <div class="ft-reg-badge">
            <span class="ft-reg-acronym">PRA</span>
            <span class="ft-reg-label">Registered</span>
          </div>
          <div class="ft-reg-badge">
            <span class="ft-reg-acronym">1990</span>
            <span class="ft-reg-label">Est.</span>
          </div>
        </div>
      </div>

      <!-- Col 2: Services -->
      <div class="ft-col">
        <h3 class="ft-col-title"><span class="ft-bar"></span>Our Services</h3>
        <ul class="ft-list">
          {['One Window Operations','Special Economic Zone','Projects in Pipeline','Business Model','Incentive Package','Major Industrial Sectors','Environmental Services','Plot Allocation'].map(s => (
            <li>
              <a href="/services" class="ft-link">
                <svg class="ft-chevron" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                {s}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Quick Links + Estates -->
      <div class="ft-col">
        <h3 class="ft-col-title"><span class="ft-bar"></span>Quick Links</h3>
        <ul class="ft-list">
          {[
            { label:'Home',                  href:'/' },
            { label:'About Us',              href:'/about' },
            { label:'One Window Solutions',  href:'/one-window-solutions' },
            { label:'Projects',              href:'/projects' },
            { label:'News & Events',         href:'/news' },
            { label:'Contact',               href:'/contact' },
          ].map(l => (
            <li>
              <a href={l.href} class="ft-link">
                <svg class="ft-chevron" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                {l.label}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="ft-col-title" style="margin-top:2rem;"><span class="ft-bar"></span>Industrial Estates</h3>
        <ul class="ft-list">
          {[
            { label:'M-3 Industrial City',           href:'/projects/m3' },
            { label:'Value Addition City',           href:'/projects/value-addition-city' },
            { label:'Allama Iqbal Industrial City',  href:'/projects/allama-iqbal-industrial-city' },
            { label:'FIEDMC Special Economic Zone',  href:'/projects/sez' },
          ].map(e => (
            <li>
              <a href={e.href} class="ft-link">
                <svg class="ft-chevron" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                {e.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div class="ft-col">
        <h3 class="ft-col-title"><span class="ft-bar"></span>Contact Us</h3>
        <div class="ft-contact-cards">
          {[
            {
              label: 'Head Office',
              value: 'M-3 Industrial City, Near Sahianwala Interchange, Faisalabad, Punjab',
              icon: `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="10" r="3"/></svg>`
            },
            {
              label: 'Phone',
              value: '+92 41 2640600',
              icon: `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`
            },
            {
              label: 'Email',
              value: 'info@fiedmc.com.pk',
              icon: `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`
            },
            {
              label: 'Office Hours',
              value: 'Mon – Fri: 9:00 AM – 5:00 PM',
              icon: `<svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`
            },
          ].map(item => (
            <div class="ft-contact-card">
              <div class="ft-contact-icon" set:html={item.icon}></div>
              <div>
                <p class="ft-contact-label">{item.label}</p>
                <p class="ft-contact-value">{item.value}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Newsletter -->
        <div class="ft-newsletter">
          <p class="ft-newsletter-label">Stay updated with FIEDMC news</p>
          <div class="ft-newsletter-row">
            <input type="email" placeholder="Your email address" class="ft-newsletter-input" aria-label="Email address"/>
            <button type="button" class="ft-newsletter-btn">Subscribe</button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="ft-bottom">
    <div class="ft-bottom-inner">
      <p class="ft-copy">
        &copy; {new Date().getFullYear()} <strong>FIEDMC</strong> — Faisalabad Industrial Estate Development &amp; Management Company. All rights reserved.
      </p>
      <p class="ft-copy-sub">Government of Punjab Initiative · Driving Industrial Growth Since 1990</p>
    </div>
  </div>

</footer>

<style>
  :root {
    --pg:    #C4952A;
    --pgh:   #D9A83C;
    --pn:    #071833;
    --ptxt:  #6B7A8D;
    --pbor:  #DDE3EC;
    --pbg:   #F4F7FB;
    --psans: 'Segoe UI', system-ui, -apple-system, sans-serif;
    --pser:  'Georgia', 'Times New Roman', serif;
  }

  .ft-footer {
    background: #ffffff;
    font-family: var(--psans);
    border-top: 3px solid var(--pg);
  }

  /* Top strip */
  .ft-top-strip { background: var(--pn); padding: 10px 0; }
  .ft-strip-inner {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap; gap: 10px 18px;
    max-width: 1280px; margin: 0 auto; padding: 0 1.5rem;
    font: 600 10.5px/1 var(--psans); letter-spacing: .09em; text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }
  .ft-strip-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--pg); opacity: .6; flex-shrink: 0; }

  /* Body */
  .ft-body { padding: 5rem 0 3.5rem; }
  .ft-container {
    max-width: 1280px; margin: 0 auto; padding: 0 1.5rem;
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.4fr; gap: 3rem; align-items: start;
  }
  @media(max-width:1100px){ .ft-container{ grid-template-columns: 1fr 1fr; gap:2.5rem; } }
  @media(max-width:580px){  .ft-container{ grid-template-columns: 1fr; gap:2rem; } }

  /* Brand */
  .ft-logo-wrap { display:inline-block; margin-bottom:1.25rem; }
  .ft-logo { height:56px; width:auto; object-fit:contain; }
  .ft-brand-desc { color:var(--ptxt); font-size:.88rem; line-height:1.85; margin-bottom:1.5rem; max-width:300px; }

  /* Social */
  .ft-social-row { display:flex; gap:8px; margin-bottom:1.75rem; }
  .ft-social-btn {
    width:36px; height:36px; border-radius:8px; border:1px solid var(--pbor);
    background:var(--pbg); display:flex; align-items:center; justify-content:center;
    color:var(--ptxt); transition:border-color .25s,background .25s,color .25s,transform .25s;
  }
  .ft-social-btn:hover { border-color:var(--pg); background:rgba(196,149,42,.08); color:var(--pg); transform:translateY(-2px); }

  /* Reg badges */
  .ft-badge-row { display:flex; gap:8px; flex-wrap:wrap; }
  .ft-reg-badge {
    display:inline-flex; flex-direction:column; align-items:center;
    background:var(--pbg); border:1px solid var(--pbor); border-radius:8px; padding:.5rem 1rem;
    border-bottom:2px solid var(--pg);
  }
  .ft-reg-acronym { font:800 1rem/1 var(--pser); color:var(--pn); }
  .ft-reg-label { font-size:.6rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--ptxt); margin-top:3px; }

  /* Col headings */
  .ft-col-title { display:flex; align-items:center; gap:10px; font:700 .95rem/1 var(--pser); color:var(--pn); margin-bottom:1.25rem; }
  .ft-bar { display:inline-block; width:3px; height:16px; background:var(--pg); border-radius:2px; flex-shrink:0; }

  /* Links */
  .ft-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; }
  .ft-list li { border-bottom:1px solid var(--pbor); }
  .ft-list li:first-child { border-top:1px solid var(--pbor); }
  .ft-link {
    display:flex; align-items:center; gap:8px; color:var(--ptxt); font-size:.87rem;
    text-decoration:none; padding:9px 4px; transition:color .2s,padding-left .2s;
  }
  .ft-link:hover { color:var(--pg); padding-left:8px; }
  .ft-chevron { color:var(--pg); opacity:.45; flex-shrink:0; transition:opacity .2s,transform .2s; }
  .ft-link:hover .ft-chevron { opacity:1; transform:translateX(2px); }

  /* Contact cards */
  .ft-contact-cards {
    display:flex; flex-direction:column;
    border:1px solid var(--pbor); border-radius:10px; overflow:hidden; margin-bottom:1.5rem;
  }
  .ft-contact-card {
    display:flex; align-items:flex-start; gap:12px; padding:12px 14px;
    border-bottom:1px solid var(--pbor); transition:background .2s;
  }
  .ft-contact-card:last-child { border-bottom:none; }
  .ft-contact-card:hover { background:var(--pbg); }
  .ft-contact-icon {
    width:32px; height:32px; border-radius:7px; flex-shrink:0; margin-top:1px;
    background:rgba(196,149,42,.08); border:1px solid rgba(196,149,42,.2);
    display:flex; align-items:center; justify-content:center; color:var(--pg);
  }
  .ft-contact-label { font:600 10.5px/1 var(--psans); letter-spacing:.05em; text-transform:uppercase; color:var(--pg); margin:0 0 4px; }
  .ft-contact-value { font-size:.84rem; color:var(--ptxt); margin:0; line-height:1.5; }

  /* Newsletter */
  .ft-newsletter {
    background:var(--pbg); border:1px solid var(--pbor); border-radius:10px;
    padding:14px 16px; border-left:3px solid var(--pg);
  }
  .ft-newsletter-label { font:600 11.5px/1 var(--psans); color:var(--pn); margin:0 0 10px; }
  .ft-newsletter-row { display:flex; gap:8px; }
  .ft-newsletter-input {
    flex:1; padding:8px 12px; border:1px solid var(--pbor); border-radius:6px;
    font:.83rem var(--psans); color:var(--pn); background:#fff; outline:none;
    transition:border-color .2s;
  }
  .ft-newsletter-input:focus { border-color:var(--pg); }
  .ft-newsletter-input::placeholder { color:#b0bac6; }
  .ft-newsletter-btn {
    padding:8px 14px; background:var(--pn); color:#fff; border:none; border-radius:6px;
    font:600 .82rem var(--psans); cursor:pointer; white-space:nowrap; transition:background .2s;
  }
  .ft-newsletter-btn:hover { background:var(--pg); color:var(--pn); }

  /* Bottom bar */
  .ft-bottom { background:var(--pn); padding:1.25rem 0; }
  .ft-bottom-inner {
    max-width:1280px; margin:0 auto; padding:0 1.5rem;
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;
  }
  .ft-copy { color:rgba(255,255,255,.35); font-size:.83rem; margin:0; }
  .ft-copy strong { color:rgba(255,255,255,.6); }
  .ft-copy-sub { color:rgba(255,255,255,.2); font-size:.78rem; margin:0; letter-spacing:.03em; }

  @media(max-width:640px){ .ft-bottom-inner{ flex-direction:column; align-items:flex-start; } }
</style>