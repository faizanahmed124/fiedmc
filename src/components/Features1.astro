---
import { Image } from 'astro:assets';
import feature1 from '../assets/images/feature1.jpg';
import feature2 from '../assets/images/feature2.jpg';
import feature3 from '../assets/images/feature3.jpg';
import feature4 from '../assets/images/feature4.jpg';
import CheckArrowIcon from '../assets/icons/CheckArrowIcon.astro';
---

<!-- Google Font: Playfair Display for headings -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

<section
  class="features-section w-full pt-24 md:pt-[12vw] lg:pt-16"
  id="features"
>
  <div style="position:relative;z-index:1;">
    <div
      class="mx-auto flex w-11/12 flex-wrap items-center md:pl-4 xl:w-[81.25rem] xl:pr-16 xl:pl-16 2xl:w-[90.625rem]"
    >
      <!-- LEFT: Text -->
      <div class="mb-12 w-full lg:mb-0 lg:w-1/2">
        <div class="lg:w-unset mx-auto w-11/12 sm:w-4/5 md:w-3/4 lg:mx-auto">

          <!-- Eyebrow -->
          <div class="features-eyebrow" data-anim="fade-right" style="transition-delay:0s;">
            <span class="features-eyebrow__dot"></span>
            Since 1990
            <span class="features-eyebrow__dot"></span>
          </div>

          <!-- Heading -->
          <h2 class="features-heading" data-anim="fade-up" style="transition-delay:0.1s;">
            <span class="heading-white">Company </span>
            <span class="heading-gold">Introduction</span>
          </h2>

          <!-- Body -->
          <p class="features-body" data-anim="fade-up" style="transition-delay:0.2s;">
            Umar &amp; Company is working since 1990 and has successfully completed many projects
            with national and international companies and factories. We deals in Mechanical Services,
            Labor Services, M.S &amp; S.S. Material Suppliers, Insulation Material Suppliers,
            Factory work, Boiler Operating, Loading &amp; Unloading, Packing, Supply Lifter,
            and Excavators. Ducting, Hot &amp; Cool Pipe Line Insulation, All aspects of Quality Control.
          </p>

          <!-- List -->
          <ul class="features-list">
            <li data-anim="fade-right" style="transition-delay:0.30s;"><CheckArrowIcon /><span>Residential &amp; Commercial Construction</span></li>
            <li data-anim="fade-right" style="transition-delay:0.42s;"><CheckArrowIcon /><span>Expert Project Management</span></li>
            <li data-anim="fade-right" style="transition-delay:0.54s;"><CheckArrowIcon /><span>Quality Materials &amp; Skilled Workforce</span></li>
          </ul>

        </div>
      </div>

      <!-- RIGHT: Images -->
      <div class="mx-auto flex w-3/4 flex-wrap justify-center sm:pr-8 lg:-mx-4 lg:w-1/2 lg:pt-10 lg:pl-4 xl:px-8">
        <div class="mb-8 w-full px-2 sm:w-1/2 lg:mb-0 lg:px-0">
          <div class="mb-4 rounded py-3 pr-2 pl-3">
            <div class="relative" data-anim="scale-in" style="transition-delay:0.15s;">
              <Image src={feature1} alt="Feature image 1"
                class="sm:mx-unset image-border mx-auto rounded-xl features-img"
                loading="eager" decoding="sync" />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
          <div class="rounded py-3 pr-2 pl-3">
            <div class="relative" data-anim="scale-in" style="transition-delay:0.3s;">
              <Image src={feature2} alt="Feature image 2"
                class="sm:mx-unset image-border mx-auto rounded-xl features-img"
                loading="eager" decoding="sync" />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
        </div>
        <div class="hidden w-1/2 px-2 pt-12 sm:inline-block lg:mt-20 lg:pt-0">
          <div class="mb-4 rounded-lg py-3 pr-2 pl-3">
            <div class="relative" data-anim="scale-in" style="transition-delay:0.45s;">
              <Image src={feature3} alt="Feature image 3"
                class="image-border rounded-xl features-img"
                loading="eager" decoding="sync" />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
          <div class="rounded-lg py-3 pr-2 pl-3">
            <div class="relative" data-anim="scale-in" style="transition-delay:0.6s;">
              <Image src={feature4} alt="Feature image 4"
                class="image-border rounded-xl features-img"
                loading="eager" decoding="sync" />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .features-section {
    position: relative;
    background: #17181b;
    overflow: hidden;
  }

  /* ── Eyebrow ── */
  .features-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #60a5fa;
    border: 1px solid rgba(96,165,250,0.25);
    border-radius: 999px;
    padding: 6px 18px;
    background: rgba(96,165,250,0.06);
    margin-bottom: 1.25rem;
  }
  .features-eyebrow__dot {
    display: inline-block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #60a5fa;
    opacity: 0.7;
  }

  /* ── Heading ── */
  .features-heading {
    font-family: 'Playfair Display', 'Georgia', serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
  .heading-white {
    color: #ffffff;
    font-style: normal;
  }
  .heading-gold {
    color: #e09a31;
    font-style: italic;
  }

  /* ── Body ── */
  .features-body {
    font-family: 'DM Sans', sans-serif;
    color: #94a3b8;
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 2rem;
    max-width: 520px;
  }

  /* ── List ── */
  .features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .features-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #e2e8f0;
    letter-spacing: 0.01em;
  }

  /* ── Images ── */
  .features-img {
    border: 1px solid rgba(96,165,250,0.15);
    transition: border-color 0.3s, transform 0.4s cubic-bezier(.22,1,.36,1);
  }
  .features-img:hover {
    border-color: rgba(96,165,250,0.4);
    transform: scale(1.02);
  }

  /* ── Scroll Animations ── */
  [data-anim] {
    opacity: 0;
    transition:
      opacity 0.75s cubic-bezier(.22,1,.36,1),
      transform 0.75s cubic-bezier(.22,1,.36,1);
  }
  [data-anim="fade-up"]    { transform: translateY(36px); }
  [data-anim="fade-right"] { transform: translateX(-28px); }
  [data-anim="scale-in"]  { transform: scale(0.92); }
  [data-anim].visible      { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    [data-anim] { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  function initFeatureAnimations() {
    var els = document.querySelectorAll('#features [data-anim]');
    if (!els.length) return;
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    els.forEach(function(el) { obs.observe(el); });
  }
  document.addEventListener('DOMContentLoaded', initFeatureAnimations);
  document.addEventListener('astro:page-load', initFeatureAnimations);
</script>