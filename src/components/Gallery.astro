---
const services = [
  {
    tag: "SUPPLY",
    number: "01",
    title: "Material Supplier",
    subtitle: "Industrial-Grade Raw Materials",
    description:
      "We supply a comprehensive range of high-quality industrial materials to construction sites, manufacturing plants, and project contractors — sourced to meet international standards.",
    features: [
      "Steel & GI Pipes — all grades & sizes",
      "Wooden Crates & Packaging Material",
      "Insulation Raw Material & Cladding",
      "Structural Steel & Metal Sections",
    ],
    badge: "In Stock & Ready",
    badgeColor: "#10b981",
    accentColor: "#3b82f6",
    image: "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=800&q=80",
  },
  {
    tag: "MECHANICAL",
    number: "02",
    title: "Mechanical Services",
    subtitle: "Plant Installation & Fabrication",
    description:
      "Our skilled mechanical team handles complete plant installation, structural fabrication, and industrial processes — delivered with safety compliance and engineering excellence.",
    features: [
      "New Plant Installation & Commissioning",
      "Welding, Grinding & Gas Cutting",
      "Structural Steel Erection",
      "Pipe Fitting & System Assembly",
    ],
    badge: "Certified Workforce",
    badgeColor: "#10b981",
    accentColor: "#f59e0b",
    image: "https://images.unsplash.com/photo-1565793298595-6a879b1d9492?w=800&q=80",
  },
  {
    tag: "INSULATION",
    number: "03",
    title: "Insulation & Ducting",
    subtitle: "Thermal & Acoustic Solutions",
    description:
      "We provide end-to-end insulation and ducting services for industrial facilities, maximizing energy efficiency and maintaining safe operating temperatures across all pipeline networks.",
    features: [
      "Steam & Hot Water Pipe Line Insulation",
      "Cold Line & Chilled Water Insulation",
      "HVAC Duct Fabrication & Installation",
      "Aluminium & GI Cladding Finishing",
    ],
    badge: "Active Projects",
    badgeColor: "#10b981",
    accentColor: "#06b6d4",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80",
  },
];
---

<section class="bg-bgDark1 w-full pt-16 pb-24">
  <div class="fade-in">
    <div class="content-container">

      <!-- ── SECTION HEADER ── -->
      <div class="mb-14 flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-xl">
          <span class="block-subtitle mb-4 block">+ OUR SERVICES +</span>
        <h2 class="block-big-title mb-5" style=" font-weight:800; font-size:clamp(2.2rem,5vw,4rem); line-height:1.15;">
  
  <span style="color:#b87716; font-style:italic;">  We Offer a Range of Industrial Services</span>
  to Meet All Your Needs
</h2>
          <p class="text-secondaryText text-base leading-relaxed">
            From raw material supply to on-site mechanical installation and thermal insulation —
            our teams operate with precision, safety, and decades of field experience.
          </p>
        </div>
        <div class="hidden lg:block shrink-0">
          <a
            href="/tailcast/services"
            class="group border-mainBorder bg-bgDark3 text-primaryText hover:bg-bgDark3Hover hover:border-secondaryColor/50 relative inline-flex items-center gap-3 overflow-hidden rounded-full border px-8 py-3.5 text-sm font-semibold uppercase tracking-widest transition-all duration-300"
          >
            <span class="absolute inset-0 rounded-full opacity-0 transition-opacity duration-300 group-hover:opacity-100"
              style="background: radial-gradient(ellipse at center, rgba(59,130,246,0.10) 0%, transparent 70%)"/>
            <span class="relative">All Services</span>
            <svg class="relative h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
              fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- ── 3-COLUMN CARD GRID ── -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <div
            class="group relative flex flex-col overflow-hidden rounded-2xl transition-all duration-500 hover:-translate-y-2"
            style="background:#131520; border:1px solid rgba(255,255,255,0.07); box-shadow:0 4px 40px rgba(0,0,0,0.3)"
          >
            <!-- Accent top bar -->
            <div class="h-[3px] w-full shrink-0"
              style={`background: linear-gradient(to right, ${s.accentColor}, transparent)`}/>

            <!-- ── Image ── -->
            <div class="relative h-52 overflow-hidden shrink-0">
              <img
                src={s.image}
                alt={s.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <!-- Overlay -->
              <div class="absolute inset-0"
                style="background:linear-gradient(to bottom, rgba(13,14,22,0.10) 0%, rgba(13,14,22,0.50) 60%, rgba(13,14,22,0.95) 100%)"/>
              <!-- Tag -->
              <div class="absolute top-4 left-4">
                <span
                  class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-bold tracking-widest backdrop-blur-sm"
                  style={`background:${s.accentColor}25; color:${s.accentColor}; border:1px solid ${s.accentColor}40`}
                >
                  <span class="h-1.5 w-1.5 rounded-full inline-block" style={`background:${s.accentColor}`}/>
                  {s.tag}
                </span>
              </div>
              <!-- Card number -->
              <div class="absolute top-4 right-4">
                <span class="font-mono text-xs text-white/30">{s.number}</span>
              </div>
              <!-- Title on image -->
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <h3 class="text-primaryText text-xl font-bold leading-tight">{s.title}</h3>
                <p class="mt-0.5 text-sm font-medium" style={`color:${s.accentColor}`}>{s.subtitle}</p>
              </div>
            </div>

            <!-- ── Card Body ── -->
            <div class="flex flex-1 flex-col p-5">
              <p class="text-secondaryText mb-5 text-sm leading-relaxed">{s.description}</p>

              <!-- Features -->
              <ul class="mb-5 flex flex-col gap-2">
                {s.features.map((f) => (
                  <li class="flex items-start gap-2 text-sm">
                    <svg class="mt-0.5 h-3.5 w-3.5 shrink-0" fill="none" stroke={s.accentColor}
                      stroke-width="2.5" viewBox="0 0 24 24">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span class="text-secondaryText/75">{f}</span>
                  </li>
                ))}
              </ul>

              <!-- Footer -->
              <div class="mt-auto flex items-center justify-between border-t pt-4"
                style="border-color:rgba(255,255,255,0.07)">
                <span class="flex items-center gap-1.5 text-sm font-semibold" style={`color:${s.badgeColor}`}>
                  <svg class="h-3.5 w-3.5" fill="none" stroke={s.badgeColor} stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {s.badge}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- ── MOBILE LOAD MORE ── -->
      <div class="mt-12 flex justify-center lg:hidden">
        <a
          href="/tailcast/services"
          class="group border-mainBorder bg-bgDark3 text-primaryText hover:bg-bgDark3Hover hover:border-secondaryColor/50 inline-flex items-center gap-3 rounded-full border px-8 py-3.5 text-sm font-semibold uppercase tracking-widest transition-all duration-300"
        >
          Load More Services
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>